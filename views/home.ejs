<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TripLink — Smart Ride Sharing</title>
  <meta name="description" content="TripLink is a next-gen ride-sharing platform where YOU decide the fare. Real-time bidding between riders and drivers.">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <style>
    /* ─── HOME-SPECIFIC ─── */
    body { overflow-x: hidden; }

    /* Animated bg blobs */
    .bg-blobs {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.18;
      animation: blobFloat 8s ease-in-out infinite;
    }

    .blob-1 {
      width: 500px; height: 500px;
      background: radial-gradient(circle, #6c63ff, transparent);
      top: -150px; left: -100px;
      animation-delay: 0s;
    }

    .blob-2 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, #00d4aa, transparent);
      top: 200px; right: -120px;
      animation-delay: -3s;
    }

    .blob-3 {
      width: 300px; height: 300px;
      background: radial-gradient(circle, #6c63ff, transparent);
      bottom: 100px; left: 30%;
      animation-delay: -5s;
    }

    @keyframes blobFloat {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33%  { transform: translate(20px, -15px) scale(1.05); }
      66%  { transform: translate(-10px, 20px) scale(0.95); }
    }

    /* Hero */
    .hero {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 80px 20px 60px;
      animation: fadeUp 0.8s ease both;
    }

    .hero-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(108,99,255,0.1);
      border: 1px solid rgba(108,99,255,0.3);
      border-radius: 50px;
      padding: 6px 16px;
      font-size: 13px;
      color: #a8a0ff;
      margin-bottom: 24px;
      letter-spacing: 0.5px;
    }

    .hero-tag span { width: 6px; height: 6px; border-radius: 50%; background: #6c63ff; animation: pulse-green 1.5s infinite; }

    .hero h1 {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(36px, 6vw, 72px);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -2px;
      margin-bottom: 20px;
      color: var(--text-primary);
    }

    .hero h1 .gradient-text {
      background: linear-gradient(135deg, #6c63ff 0%, #00d4aa 60%, #22c55e 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      font-size: 18px;
      color: var(--text-secondary);
      max-width: 520px;
      margin: 0 auto 36px;
      line-height: 1.7;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .hero-actions .btn-big {
      padding: 16px 36px;
      border-radius: 14px;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: none;
      width: auto;
    }

    .btn-big.primary {
      background: linear-gradient(135deg, #6c63ff, #5a52e0);
      color: white;
      box-shadow: 0 8px 30px rgba(108,99,255,0.4);
    }

    .btn-big.primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(108,99,255,0.5);
    }

    .btn-big.secondary {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.12);
      color: var(--text-primary);
    }

    .btn-big.secondary:hover {
      background: rgba(255,255,255,0.09);
      transform: translateY(-3px);
    }

    /* Stats row */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      max-width: 700px;
      margin: 60px auto 20px;
      animation: fadeUp 0.8s 0.2s ease both;
    }

    .stat-item {
      text-align: center;
      padding: 24px 16px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 18px;
      transition: all 0.3s ease;
    }

    .stat-item:hover {
      background: rgba(108,99,255,0.06);
      border-color: rgba(108,99,255,0.2);
      transform: translateY(-3px);
    }

    .stat-item .num {
      font-family: 'Outfit', sans-serif;
      font-size: 32px;
      font-weight: 800;
      background: linear-gradient(135deg, #6c63ff, #00d4aa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .stat-item .lbl {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    /* How it works */
    .section {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 20px 24px 60px;
      animation: fadeUp 0.8s 0.35s ease both;
    }

    .section-title {
      text-align: center;
      margin-bottom: 40px;
    }

    .section-title h2 {
      font-family: 'Outfit', sans-serif;
      font-size: 28px;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 8px;
    }

    .section-title p {
      color: var(--text-muted);
      font-size: 15px;
    }

    .how-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .how-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 20px;
      padding: 28px 22px;
      text-align: center;
      transition: all 0.35s ease;
      cursor: default;
      position: relative;
      overflow: hidden;
    }

    .how-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #6c63ff, #00d4aa);
      transform: scaleX(0);
      transition: transform 0.35s ease;
    }

    .how-card:hover::before { transform: scaleX(1); }

    .how-card:hover {
      background: rgba(108,99,255,0.06);
      border-color: rgba(108,99,255,0.2);
      transform: translateY(-6px);
      box-shadow: 0 20px 50px rgba(0,0,0,0.4);
    }

    .how-card .icon {
      font-size: 36px;
      margin-bottom: 14px;
      display: block;
      animation: float 3s ease-in-out infinite;
    }

    .how-card:nth-child(2) .icon { animation-delay: -1s; }
    .how-card:nth-child(3) .icon { animation-delay: -2s; }

    .how-card h3 {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 8px;
    }

    .how-card p {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.65;
    }

    /* CTA Banner */
    .cta-banner {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto 60px;
      padding: 0 24px;
      animation: fadeUp 0.8s 0.5s ease both;
    }

    .cta-inner {
      background: linear-gradient(135deg, rgba(108,99,255,0.15), rgba(0,212,170,0.1));
      border: 1px solid rgba(108,99,255,0.3);
      border-radius: 24px;
      padding: 40px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .cta-inner::after {
      content: '🚗';
      position: absolute;
      right: 40px;
      bottom: -10px;
      font-size: 80px;
      opacity: 0.12;
    }

    .cta-inner h2 {
      font-family: 'Outfit', sans-serif;
      font-size: 26px;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 10px;
    }

    .cta-inner p {
      color: var(--text-secondary);
      margin-bottom: 24px;
    }

    .cta-btns {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Footer */
    .footer {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 24px;
      color: var(--text-muted);
      font-size: 13px;
      border-top: 1px solid var(--border);
    }

    @media (max-width: 640px) {
      .how-grid { grid-template-columns: 1fr; }
      .stats-row { grid-template-columns: 1fr 1fr; }
      .stats-row .stat-item:last-child { grid-column: span 2; }
      .cta-inner { padding: 28px 20px; }
    }
  </style>
</head>
<body>

<!-- Animated background blobs -->
<div class="bg-blobs">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<!-- NAVBAR -->
<div class="container" style="position:relative;z-index:1;">
  <nav class="navbar">
    <div class="logo">⚡ TripLink</div>
    <div class="nav-links">
      <% if (user) { %>
        <a href="/<%= user.role %>/dashboard">Dashboard</a>
        <a href="/auth/logout">Logout</a>
      <% } else { %>
        <a href="/auth/login">Sign In</a>
        <a href="/auth/register" class="btn-primary">Get Started</a>
      <% } %>
    </div>
  </nav>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-tag">
    <span></span>
    Real-time ride bidding — You control the fare
  </div>

  <h1>
    Your Ride,<br>
    <span class="gradient-text">Your Price.</span>
  </h1>

  <p>
    TripLink is a next-gen platform where riders set their own fare and drivers choose to accept.
    No surge pricing — just fair, transparent travel.
  </p>

  <div class="hero-actions">
    <% if (user) { %>
      <a href="/<%= user.role %>/dashboard" class="btn-big primary">🚀 Go to Dashboard</a>
    <% } else { %>
      <a href="/auth/register" class="btn-big primary">🚀 Start Riding Free</a>
      <a href="/auth/login" class="btn-big secondary">Sign In →</a>
    <% } %>
  </div>

  <!-- Stats row -->
  <div class="stats-row">
    <div class="stat-item">
      <div class="num">₹0</div>
      <div class="lbl">Surge Pricing</div>
    </div>
    <div class="stat-item">
      <div class="num">100%</div>
      <div class="lbl">Fare Control</div>
    </div>
    <div class="stat-item">
      <div class="num">Real-time</div>
      <div class="lbl">Driver Matching</div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section">
  <div class="section-title">
    <h2>How TripLink Works</h2>
    <p>Three simple steps — no hidden surprises.</p>
  </div>

  <div class="how-grid">
    <div class="how-card">
      <span class="icon">📍</span>
      <h3>Enter Your Route</h3>
      <p>Type your pickup and drop location. We instantly calculate the estimated distance and suggested fare.</p>
    </div>

    <div class="how-card">
      <span class="icon">💰</span>
      <h3>Set Your Fare</h3>
      <p>See the estimated cost and decide how much you want to offer. You're always in control — no forced pricing.</p>
    </div>

    <div class="how-card">
      <span class="icon">🤝</span>
      <h3>Driver Accepts</h3>
      <p>Your request goes live to nearby drivers in real-time. A driver who likes your offer accepts instantly.</p>
    </div>
  </div>
</section>

<!-- CTA BANNER -->
<% if (!user) { %>
<div class="cta-banner">
  <div class="cta-inner">
    <h2>Ready to take control?</h2>
    <p>Join thousands of riders who decide what they pay. Sign up free in 30 seconds.</p>
    <div class="cta-btns">
      <a href="/auth/register" class="btn-big primary">Register as Rider 🏃</a>
      <a href="/auth/register" class="btn-big secondary">Join as Driver 🚗</a>
    </div>
  </div>
</div>
<% } %>

<footer class="footer">
  &copy; 2025 TripLink. Built for fair rides &mdash; by riders, for riders.
</footer>

</body>
</html>