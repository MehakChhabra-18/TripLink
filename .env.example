# ============================================================
# TripLink Backend — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git

# ─── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL (Primary DB) ──────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/triplink?schema=public

# ─── MongoDB (Tracking/Legacy) ────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/triplink
# For Atlas:
# MONGO_URI=mongodb+srv://user:password@cluster0.xxx.mongodb.net/triplink

# ─── JWT Authentication ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-64-characters
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Razorpay ─────────────────────────────────────────────────
# Get keys at: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Cloudinary ───────────────────────────────────────────────
# Sign up at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ─────────────────────────────────────────────
# Gmail: Enable 2FA, then create App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# ─── Google Maps ──────────────────────────────────────────────
# Enable: Maps JS API, Directions API, Distance Matrix API
GOOGLE_MAPS_API=AIzaSy...

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Docker Compose ───────────────────────────────────────────
POSTGRES_USER=triplink
POSTGRES_PASSWORD=secret
POSTGRES_DB=triplink
